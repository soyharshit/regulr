// This is your Prisma schema file (LOCAL DEV — SQLite).
// The production schema is prisma/schema.postgres.prisma (Postgres).
// KEEP THE MODELS IN THESE TWO FILES IDENTICAL — only the datasource provider differs.
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Cafe {
  id            String        @id @default(uuid())
  slug          String        @unique
  name          String
  isActive      Boolean       @default(true)
  brandColor    String?       // hex color for theming, e.g. "#4A2C23"
  logoUrl       String?       // URL to cafe logo image
  coverImageUrl String?       // URL to cover/banner image
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  menuItems     MenuItem[]
  orders        Order[]
  customers     Customer[]
  referrals     Referral[]
  settings      CafeSettings?
  staff         User[]             @relation("CafeStaff")
  redemptions   RewardRedemption[]
  checkIns      CheckIn[]
  fortuneBoxes  FortuneBox[]
}

model CafeSettings {
  id               String   @id @default(uuid())
  cafeId           String   @unique
  loyaltyEnabled   Boolean  @default(true)
  pointsPerRupee   Float    @default(1)
  streakMilestones String   @default("[3,7,14,30]") // JSON array of numbers
  coupons          String   @default("[]") // JSON array of { code, discountPercent?, discountPaise?, maxUses? }
  rewards          String   @default("[]") // JSON array of { id, title, cost, description? } redeemable with points
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cafe             Cafe     @relation(fields: [cafeId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String?    // optional, for credential-based logins (e.g., owner/admin accounts)
  name          String?
  role          String     @default("CUSTOMER") // SUPERADMIN, OWNER, STAFF, CUSTOMER
  cafeId        String?    // the cafe an OWNER/STAFF user belongs to (null for SUPERADMIN/CUSTOMER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  customers     Customer[]
  cafe          Cafe?      @relation("CafeStaff", fields: [cafeId], references: [id], onDelete: SetNull)
}

model Customer {
  id              String     @id @default(uuid())
  cafeId          String
  userId          String
  points          Int        @default(0)
  tier            String     @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  streakCount     Int        @default(0)
  streakCalendar  String     @default("[]") // JSON serialized array of ISO date strings (e.g. '["2026-07-04"]')
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  cafe            Cafe       @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders          Order[]
  referralsMade   Referral[] @relation("ReferrerRelation")
  referredBy      Referral?  @relation("ReferredRelation")
  redemptions     RewardRedemption[]
  checkIns        CheckIn[]
  fortuneBoxes    FortuneBox[]

  @@unique([cafeId, userId])
}

model MenuItem {
  id          String      @id @default(uuid())
  cafeId      String
  name        String
  description String?
  price       Int         // in paise
  zomatoPrice Int?        // price in paise on Zomato/Swiggy (for price comparison)
  category    String      @default("beverages")
  isAvailable Boolean     @default(true)
  imageUrl    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  cafe        Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
}

model Order {
  id              String      @id @default(uuid())
  cafeId          String
  customerId      String?     // Nullable for walk-ins/guest checkouts
  tableNumber     Int?        // dine-in table (from the QR code), null for takeaway
  subtotalAmount  Int         @default(0) // in paise, before discounts
  discountAmount  Int         @default(0) // in paise, coupon + points redemption combined
  couponCode      String?
  pointsRedeemed  Int         @default(0)
  pointsEarned    Int         @default(0) // awarded on completion
  bonusPoints     Int         @default(0) // scratch-card surprise bonus, awarded once
  scratchedAt     DateTime?   // when the customer revealed the scratch card
  totalAmount     Int         // in paise, final amount charged
  status          String      @default("PENDING") // PENDING, PREPARING, READY, COMPLETED, CANCELLED
  paymentMethod   String      @default("CASH") // CASH, UPI, RAZORPAY
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  cafe            Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  customer        Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  price      Int      // in paise (historical price at time of purchase)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model Referral {
  id            String   @id @default(uuid())
  cafeId        String
  referrerId    String
  referredId    String   @unique
  status        String   @default("PENDING") // PENDING, COMPLETED
  pointsAwarded Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cafe          Cafe     @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  referrer      Customer @relation("ReferrerRelation", fields: [referrerId], references: [id], onDelete: Cascade)
  referred      Customer @relation("ReferredRelation", fields: [referredId], references: [id], onDelete: Cascade)
}

model RewardRedemption {
  id          String   @id @default(uuid())
  cafeId      String
  customerId  String
  rewardTitle String
  cost        Int      // points spent
  code        String   @unique // voucher code shown to the customer / verified by staff
  status      String   @default("ACTIVE") // ACTIVE, USED, EXPIRED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cafe        Cafe     @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String   // who performed the action
  targetId  String?  // who was impersonated
  action    String   // e.g. "IMPERSONATE_START", "IMPERSONATE_END"
  metadata  String   @default("{}") // JSON string
  createdAt DateTime @default(now())
}

model CheckIn {
  id         String   @id @default(uuid())
  cafeId     String
  customerId String
  date       String   // ISO date "2026-07-06"
  points     Int      // points earned that day
  createdAt  DateTime @default(now())

  cafe       Cafe     @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, date])
}

model FortuneBox {
  id         String   @id @default(uuid())
  cafeId     String
  customerId String
  progress   Int      @default(0) // orders collected (0-5)
  reward     String?  // JSON { type: "points"|"coupon", value: number } - revealed on open
  openedAt   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cafe       Cafe     @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([cafeId, customerId])
}
