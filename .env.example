# ── Local development (SQLite) ─────────────────────────────────────────────
# Uses prisma/schema.prisma (provider = sqlite).
DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-strong-secret"
NEXT_PUBLIC_ROOT_DOMAIN="localhost"

# ── Production (Vercel + Postgres) ─────────────────────────────────────────
# Set these in the Vercel dashboard → Settings → Environment Variables.
# The build uses prisma/schema.postgres.prisma (provider = postgresql).
#
# DATABASE_URL    — Postgres pooled connection string:
#                   postgresql://user:pass@host:5432/dbname?sslmode=require
# NEXTAUTH_SECRET — random secret:  openssl rand -base64 32
# NEXTAUTH_URL    — deployed URL, e.g. https://your-app.vercel.app
# NEXT_PUBLIC_ROOT_DOMAIN — (optional) custom domain for subdomain routing, e.g. regulr.in
